# ============================================================
# Poker Pi — Template de variáveis de ambiente
# ============================================================
#
# COMO USAR:
# 1. Copie este arquivo para `.env.local` na raiz do projeto
# 2. Substitua os valores abaixo pelos reais (do seu Supabase Dashboard)
# 3. NUNCA commite `.env.local` (já está no .gitignore)
#
# Onde pegar cada valor:
# - Acesse https://supabase.com/dashboard/project/[seu-project-ref]/settings/api
# - URL: campo "Project URL"
# - PUBLISHABLE_KEY: campo "anon" "public" (sob "Project API keys")
# - SERVICE_ROLE_KEY: campo "service_role" "secret" (sob "Project API keys")
#
# ============================================================

# URL pública do seu projeto Supabase (pode ser commitada — não é secret)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Chave pública publishable (exposta ao cliente — sujeita a RLS)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxx

# Chave de serviço (SECRET — JAMAIS expor ao cliente; bypassa RLS).
# Usada em operações admin server-only (ex.: criar admin user via API).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# V1.1: CRON_SECRET removido — não há mais cron de avanço automático de blinds.
# Admin avança nível manualmente no painel.

# ============================================================
# Cloudinary — hospedagem dos vídeos-convite personalizados
# ============================================================
# Onde achar (Cloudinary Console → topo, "Product Environment Credentials"):
# - Cloud name: público, aparece em toda URL de entrega → NEXT_PUBLIC.
# - API Key / API Secret: server-only (upload assinado). NUNCA expor ao client.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ============================================================
# Asaas — gateway de pagamento (ingressos)
# ============================================================
# Interruptor de ambiente: "sandbox" (teste, sem dinheiro real) ou "production".
# O código escolhe a chave + a URL base a partir deste valor.
ASAAS_ENV=sandbox
ASAAS_API_KEY_SANDBOX=
ASAAS_API_KEY_PRODUCTION=

# ============================================================
# Resend — envio de e-mail (ingressos)
# ============================================================
RESEND_API_KEY=

# ============================================================
# Webhook Asaas — autenticação e site URL
# ============================================================
# Token que autentica o webhook do Asaas (você cria no painel Asaas e repete aqui).
ASAAS_WEBHOOK_TOKEN=
# URL pública do site (usada no QR e nos links do e-mail). Em dev: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
